{
    // 🤖 TicketsPlease MCP Server Konfiguration
    // Docs: https://code.visualstudio.com/docs/copilot/chat/mcp-servers

    "servers": {

        // ═══════════════════════════════════════════════════════════
        // 🎭 Playwright – E2E Browser Testing & Automation
        // Für automatisierte User-Journeys (Kanban Drag&Drop, Login, etc.)
        // Docs: https://playwright.dev/docs/mcp
        // ═══════════════════════════════════════════════════════════
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ]
        },

        // ═══════════════════════════════════════════════════════════
        // 🐙 GitHub – Issues, PRs, Repositories, Code Search
        // Für Issue-Tracking, PR-Management und Code-Search
        // Docs: https://github.com/github/github-mcp-server
        // ═══════════════════════════════════════════════════════════
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@anthropic-ai/github-mcp-server@latest"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
            }
        },

        // ═══════════════════════════════════════════════════════════
        // 📁 Filesystem – Erweiterter Dateizugriff
        // Für Lesen/Schreiben von Dateien außerhalb des Workspaces
        // Docs: https://www.npmjs.com/package/@modelcontextprotocol/server-filesystem
        // ═══════════════════════════════════════════════════════════
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem@latest",
                "d:/DEV/Tickets"
            ]
        },

        // ═══════════════════════════════════════════════════════════
        // 🧠 Memory – Persistent Knowledge Graph
        // Für projektübergreifendes Wissen und Kontext-Speicherung
        // Docs: https://www.npmjs.com/package/@modelcontextprotocol/server-memory
        // ═══════════════════════════════════════════════════════════
        "memory": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory@latest"
            ]
        },

        // ═══════════════════════════════════════════════════════════
        // 🔍 Sequential Thinking – Komplexe Problemlösung
        // Für strukturiertes Denken bei Architektur-Entscheidungen
        // Docs: https://www.npmjs.com/package/@modelcontextprotocol/server-sequential-thinking
        // ═══════════════════════════════════════════════════════════
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking@latest"
            ]
        },

        // ═══════════════════════════════════════════════════════════
        // 🗄️ MSSQL – SQL Server Datenbankzugriff
        // Für direkte SQL-Abfragen, Schema-Inspektion, Migration-Tests
        // Docs: https://www.npmjs.com/package/@connorbritain/mssql-mcp-server
        // ═══════════════════════════════════════════════════════════
        "mssql": {
            "command": "npx",
            "args": [
                "-y",
                "@connorbritain/mssql-mcp-server@latest"
            ],
            "env": {
                "SERVER_NAME": "localhost",
                "DATABASE_NAME": "TicketsPlease"
            }
        },

        // ═══════════════════════════════════════════════════════════
        // 🌸 Flowbite – Tailwind UI Component Library
        // Für Zugriff auf Flowbite-Komponenten, Theme-Generator,
        // und Design-to-Code (Tailwind-basierte UI-Bausteine)
        // Docs: https://flowbite.com/docs/getting-started/mcp/
        // ═══════════════════════════════════════════════════════════
        "flowbite": {
            "command": "npx",
            "args": [
                "-y",
                "flowbite-mcp@latest"
            ]
        }
    }
}
